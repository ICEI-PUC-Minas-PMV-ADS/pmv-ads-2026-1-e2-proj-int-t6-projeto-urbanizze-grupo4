@page "{id:int}"
@model Urbanizze.Pages.Denuncias.DetalhesModel
@{
    ViewData["Title"] = "Detalhes da Denúncia";
}

<style>
    .detalhe-wrap { display: flex; gap: 24px; }
    .detalhe-info { width: 340px; background: white; border-radius: 14px; border: 1px solid #E5DED1; padding: 24px; flex-shrink: 0; }
    .detalhe-info h3 { font-size: 15px; font-weight: 600; margin-bottom: 20px; color: #1F2937; }
    .info-label { font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #D98936; margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
    .info-value { font-size: 15px; font-weight: 500; color: #1F2937; margin-bottom: 20px; }
    .info-desc { font-size: 14px; color: #555; line-height: 1.7; }
    .chat-wrap { flex: 1; background: white; border-radius: 14px; border: 1px solid #E5DED1; display: flex; flex-direction: column; overflow: hidden; }
    .chat-header { padding: 20px 24px; border-bottom: 1px solid #E5DED1; }
    .chat-header h3 { font-size: 15px; font-weight: 600; color: #1F2937; margin: 0; }
    .chat-header small { color: #999; font-size: 13px; }
    .chat-messages { flex: 1; padding: 20px 24px; overflow-y: auto; display: flex; flex-direction: column; gap: 14px; min-height: 300px; max-height: 420px; background: #FDFBF7; }
    .msg-bubble { max-width: 70%; padding: 14px 16px; border-radius: 14px; font-size: 14px; line-height: 1.6; }
    .msg-left { background: white; border: 1px solid #E5DED1; align-self: flex-start; }
    .msg-right { background: #D98936; color: white; align-self: flex-end; }
    .msg-author { font-size: 12px; font-weight: 600; margin-bottom: 4px; color: #555; }
    .msg-right .msg-author { color: rgba(255,255,255,0.8); }
    .msg-time { font-size: 11px; color: #999; margin-top: 6px; display: flex; align-items: center; gap: 4px; }
    .msg-right .msg-time { color: rgba(255,255,255,0.7); }
    .chat-input { padding: 16px 24px; border-top: 1px solid #E5DED1; display: flex; gap: 12px; background: white; }
    .chat-input input { flex: 1; padding: 14px 16px; border: 1px solid #E2DBCF; border-radius: 12px; outline: none; font-size: 14px; background: #FDFBF7; }
    .chat-input button { background: #D98936; color: white; border: none; padding: 14px 20px; border-radius: 12px; cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 8px; }
    .chat-input button:hover { opacity: 0.9; }
    .status-badge { display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; }
    .status-aberta { background: #DFF3E6; color: #2E8B57; border: 1px solid #CBE8D5; }
    .status-other { background: #FEF3C7; color: #92400E; border: 1px solid #FDE68A; }
    .back-link { display: inline-flex; align-items: center; gap: 8px; color: #D98936; font-weight: 500; text-decoration: none; margin-bottom: 20px; font-size: 14px; }
    .back-link:hover { opacity: 0.8; }
    .avatar-sm { width: 36px; height: 36px; border-radius: 50%; background: #D98936; color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 13px; }
    .user-row { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
</style>

<a href="/Denuncias" class="back-link">
    <i class="fa-solid fa-arrow-left"></i>
    Voltar para denúncias
</a>

<div style="display:flex; align-items:center; gap:14px; margin-bottom:24px;">
    <h2 style="font-size:26px; font-weight:700; color:#1F2937; margin:0;">@Model.Denuncia.Titulo</h2>
    @if (Model.Denuncia.StatusDenuncia == StatusDenuncia.ABERTA)
    {
        <span class="status-badge status-aberta">● Aberta</span>
    }
    else
    {
        <span class="status-badge status-other">● @Model.Denuncia.StatusDenuncia.ToString().Replace("_", " ")</span>
    }
</div>

<div class="detalhe-wrap">
    <div class="detalhe-info">
        <h3>Informações da Denúncia</h3>

        <div class="info-label"><i class="fa-regular fa-user"></i> Cidadão</div>
        @{
            var iniciais = string.Join("", Model.Denuncia.Cidadao.Nome.Split(' ').Take(2).Select(p => p[0]));
        }
        <div class="user-row">
            <div class="avatar-sm">@iniciais</div>
            <span class="info-value" style="margin:0;">@Model.Denuncia.Cidadao.Nome</span>
        </div>

        <div class="info-label"><i class="fa-solid fa-building"></i> Departamento</div>
        <div class="info-value">@Model.Denuncia.Departamento?.Nome</div>

        <div class="info-label"><i class="fa-regular fa-calendar"></i> Data da Denúncia</div>
        <div class="info-value">@Model.Denuncia.CriadoEm.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR"))</div>

        <div class="info-label"><i class="fa-regular fa-file-lines"></i> Descrição</div>
        <div class="info-desc">@Model.Denuncia.Descricao</div>
    </div>

    <div class="chat-wrap">
        <div class="chat-header">
            <h3>Comunicação</h3>
            <small>@Model.Mensagens.Count mensagem(ns)</small>
        </div>

        <div class="chat-messages" id="chat-box">
            @if (!Model.Mensagens.Any())
            {
                <p style="color:#999; text-align:center; margin-top:40px;">Nenhuma mensagem ainda.</p>
            }
            @foreach (var msg in Model.Mensagens)
            {
                bool isFuncionario = msg.FuncionarioId != null;
                string autor = isFuncionario
                    ? (msg.Funcionario?.Cidadao?.Nome ?? "Funcionário")
                    : (msg.Cidadao?.Nome ?? "Cidadão");
                string classe = isFuncionario ? "msg-right" : "msg-left";

                <div class="msg-bubble @classe">
                    <div class="msg-author">@autor</div>
                    @msg.Texto
                    <div class="msg-time">
                        <i class="fa-regular fa-clock"></i>
                        @msg.CriadoEm.ToLocalTime().ToString("HH:mm")
                    </div>
                </div>
            }
        </div>

        <form method="post" asp-route-id="@Model.Denuncia.Id">
            <div class="chat-input">
                <input type="text" name="NovaMsg" placeholder="Digite sua mensagem..." autocomplete="off" />
                <button type="submit">
                    <i class="fa-solid fa-paper-plane"></i>
                    Enviar
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    const chatBox = document.getElementById('chat-box');
    if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;
</script>