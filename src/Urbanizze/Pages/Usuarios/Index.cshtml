@page
@model Urbanizze.Pages.Usuarios.IndexModel
@{
    ViewData["Title"] = "Usuários";
}

<div class="section-header">
    <span class="section-tag">GESTÃO</span>
    <h2>Usuários</h2>
</div>

<div class="filters">
    <button class="filter-dark">
        <i class="fa-solid fa-sliders"></i>
        Filtros
    </button>
    <button class="filter-light">Todos os cargos</button>
    <button class="filter-light">Ativos</button>
</div>

<div class="users-actions">
    <div class="user-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder="Buscar usuário" />
    </div>
    <button class="new-user-btn">
        <i class="fa-solid fa-plus"></i>
        Novo usuário
    </button>
</div>

<section class="user-list">
    <table>
        <thead>
            <tr>
                <th>USUÁRIO</th>
                <th>E-MAIL</th>
                <th>CARGO</th>
                <th>CRIAÇÃO</th>
                <th>STATUS</th>
                <th>AÇÕES</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var funcionario in Model.Funcionarios)
            {
                var iniciais = string.Join("", funcionario.Cidadao.Nome
                    .Split(' ')
                    .Take(2)
                    .Select(p => p[0]));

                <tr>
                    <td>
                        <div class="user-name">
                            <div class="user-circle">@iniciais</div>
                            @funcionario.Cidadao.Nome
                        </div>
                    </td>
                    <td class="user-email">@funcionario.Cidadao.Email</td>
                    <td>@(funcionario.Departamento?.Nome ?? "—")</td>
                    <td>@funcionario.CriadoEm.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (funcionario.Cidadao.Ativo)
                        {
                            <span class="status active">Ativo</span>
                        }
                        else
                        {
                            <span class="status inactive">Inativo</span>
                        }
                    </td>
                    <td class="actions">
                        <div class="dropdown">
                            <button class="dropdown-btn">⋮</button>
                            <div class="dropdown-content">
                                <a href="#">Editar</a>
                                <a href="#" class="delete-option">Excluir</a>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div style="padding: 14px 20px; font-size: 13px; color: #777;">
        Exibindo <strong>1–@Model.Funcionarios.Count</strong> de <strong>@Model.Funcionarios.Count</strong> registros
    </div>
</section>