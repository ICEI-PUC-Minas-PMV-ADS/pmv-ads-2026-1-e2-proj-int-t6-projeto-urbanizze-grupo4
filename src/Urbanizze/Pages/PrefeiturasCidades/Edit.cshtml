@page "{id:int}"
@model Urbanizze.Pages.PrefeiturasCidades.EditModel

@{
    ViewData["Title"] = "Editar Prefeitura/Cidade";
}

<h1 class="fs-4 fw-bold mb-3">Editar Prefeitura / Cidade</h1>

<div class="card border p-4" style="max-width: 600px;">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Prefeitura.Id" />

        <div class="mb-3">
            <label asp-for="Prefeitura.Nome" class="form-label">Nome</label>
            <input asp-for="Prefeitura.Nome" class="form-control" />
            <span asp-validation-for="Prefeitura.Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Prefeitura.Uf" class="form-label">UF</label>
            <input asp-for="Prefeitura.Uf" class="form-control" maxlength="2" style="width: 100px;" />
            <span asp-validation-for="Prefeitura.Uf" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-dark">Salvar</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
