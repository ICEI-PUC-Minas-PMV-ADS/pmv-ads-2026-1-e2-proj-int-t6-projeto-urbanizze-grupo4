@page
@model Urbanizze.Pages.PrefeiturasCidades.IndexModel

@{
    ViewData["Title"] = "Prefeituras / Cidades";
}

<h1 class="fs-4 fw-bold mb-3">Prefeituras / Cidades</h1>

<div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    <div class="ms-auto d-flex gap-2">
        <input type="text" class="form-control form-control-sm" style="width:180px" placeholder="Buscar cidade..." />
        <a asp-page="./Create" class="btn btn-sm btn-dark">+ Nova cidade</a>
    </div>
</div>

<div class="card border">
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Nome</th>
                <th>UF</th>
                <th>Departamentos</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Prefeituras)
            {
                <tr>
                    <td>
                        <span class="badge bg-secondary me-2">@p.Nome.Substring(0, Math.Min(2, p.Nome.Length)).ToUpper()</span>
                        @p.Nome
                    </td>
                    <td>@p.Uf</td>
                    <td>@p.Departamentos.Count</td>
                    <td>
                        <a asp-page="./Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                        <a asp-page="./Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="px-3 py-2 text-muted small border-top">
        Exibindo @Model.Prefeituras.Count registros
    </div>
</div>
