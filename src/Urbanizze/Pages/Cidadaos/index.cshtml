@page
@model Urbanizze.Pages.Cidadaos.IndexModel

@{
    ViewData["Title"] = "Cidadãos";
}

<h1 class="fs-4 fw-bold mb-3">Cidadãos Cadastrados</h1>

<div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    <div class="ms-auto d-flex gap-2">
        <input type="text" class="form-control form-control-sm" style="width:180px" placeholder="Buscar cidadão..." />
    </div>
</div>

<div class="card border">
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Cidadão</th>
                <th>E-mail</th>
                <th>Telefone</th>
                <th>CPF</th>
                <th>Cadastro</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Cidadaos)
            {
                <tr>
                    <td>
                        <span class="badge bg-secondary me-2">@c.Nome.Substring(0, Math.Min(2, c.Nome.Length)).ToUpper()</span>
                        @c.Nome
                    </td>
                    <td>@c.Email</td>
                    <td>@c.Telefone</td>
                    <td>@c.Cpf</td>
                    <td>@c.CriadoEm.ToString("dd/MM/yyyy")</td>
                    <td>
                        <span class="badge @(c.Ativo ? "text-bg-success" : "text-bg-warning")">
                            @(c.Ativo ? "Ativo" : "Inativo")
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="px-3 py-2 text-muted small border-top">
        Exibindo @Model.Cidadaos.Count registros
    </div>
</div>
