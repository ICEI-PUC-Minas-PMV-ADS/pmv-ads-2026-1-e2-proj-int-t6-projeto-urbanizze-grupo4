@page
@model Urbanizze.Pages.Cidadaos.IndexModel

@{
    ViewData["Title"] = "Cidadãos";
}

<div class="section-header">
    <span class="section-tag">CIDADÃOS</span>
    <h2>Cidadãos Cadastrados</h2>
</div>

<div class="denuncias-toolbar">
    <div class="filters">
        <button class="filter-dark">
            <i class="fa-solid fa-sliders"></i>
            Filtros
        </button>
        <button class="filter-light">Todas as cidades</button>
        <button class="filter-light">Ativos</button>
    </div>
    <div class="users-actions">
        <div class="user-search">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" placeholder="Buscar cidadão..." />
        </div>
        <button class="new-user-btn">
            <i class="fa-solid fa-plus"></i>
            Novo cidadão
        </button>
    </div>
</div>

<section class="user-list">
    <table>
        <thead>
            <tr>
                <th>CIDADÃO</th>
                <th>E-MAIL</th>
                <th>TELEFONE</th>
                <th>CIDADE</th>
                <th>CADASTRO</th>
                <th>STATUS</th>
                <th>AÇÕES</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Cidadaos)
            {
                var iniciais = string.Join("", c.Nome
                    .Split(' ')
                    .Take(2)
                    .Select(p => p[0].ToString().ToUpper()));

                var cidade = Model.CidadaoCidade.GetValueOrDefault(c.Id, "—");

                <tr>
                    <td>
                        <div class="user-name">
                            <div class="user-circle">@iniciais</div>
                            @c.Nome
                        </div>
                    </td>
                    <td class="user-email">@c.Email</td>
                    <td>@c.Telefone</td>
                    <td>@cidade</td>
                    <td>@c.CriadoEm.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (c.Ativo)
                        {
                            <span class="status active">Ativo</span>
                        }
                        else
                        {
                            <span class="status inactive">Inativo</span>
                        }
                    </td>
                    <td class="actions">
                        <div class="dropdown">
                            <button class="dropdown-btn">&#8942;</button>
                            <div class="dropdown-content">
                                <a href="#">Editar</a>
                                <a href="#" class="delete-option">Excluir</a>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div style="padding: 14px 20px; font-size: 13px; color: #777;">
        Exibindo <strong>1–@Model.Cidadaos.Count</strong> de <strong>@Model.Cidadaos.Count</strong> registros
    </div>
</section>
