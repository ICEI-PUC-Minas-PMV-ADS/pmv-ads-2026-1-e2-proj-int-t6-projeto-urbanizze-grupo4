@page "{id:int}"
@model Urbanizze.Pages.Departamentos.EditModel

@{
    ViewData["Title"] = "Editar Departamento";
}

<h1 class="fs-4 fw-bold mb-3">Editar Departamento</h1>

<div class="card border p-4" style="max-width: 600px;">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Departamento.Id" />

        <div class="mb-3">
            <label asp-for="Departamento.Nome" class="form-label">Nome</label>
            <input asp-for="Departamento.Nome" class="form-control" />
            <span asp-validation-for="Departamento.Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Departamento.Descricao" class="form-label">Descrição</label>
            <textarea asp-for="Departamento.Descricao" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Departamento.Descricao" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Departamento.PrefeituraCidadeId" class="form-label">Prefeitura / Cidade</label>
            <select asp-for="Departamento.PrefeituraCidadeId" class="form-select"
                    asp-items="Model.Prefeituras">
                <option value="">-- Selecione --</option>
            </select>
            <span asp-validation-for="Departamento.PrefeituraCidadeId" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-dark">Salvar</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
