@page "{id:int}"
@model Urbanizze.Pages.Departamentos.DeleteModel

@{
    ViewData["Title"] = "Excluir Departamento";
}

<h1 class="fs-4 fw-bold mb-3">Excluir Departamento</h1>

<div class="card border p-4" style="max-width: 600px;">
    <h5>Tem certeza que deseja excluir?</h5>
    <dl class="row mt-3">
        <dt class="col-sm-4">Nome</dt>
        <dd class="col-sm-8">@Model.Departamento.Nome</dd>
        <dt class="col-sm-4">Descrição</dt>
        <dd class="col-sm-8">@Model.Departamento.Descricao</dd>
        <dt class="col-sm-4">Prefeitura</dt>
        <dd class="col-sm-8">@Model.Departamento.PrefeituraCidade.Nome</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Departamento.Id" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>
