@page "{id:int}"
@model Urbanizze.Pages.Funcionarios.DeleteModel

@{
    ViewData["Title"] = "Excluir Funcionário";
}

<h1 class="fs-4 fw-bold mb-3">Excluir Funcionário</h1>

<div class="card border p-4" style="max-width: 600px;">
    <h5>Tem certeza que deseja excluir?</h5>
    <dl class="row mt-3">
        <dt class="col-sm-4">Cidadão</dt>
        <dd class="col-sm-8">@Model.Funcionario.Cidadao.Nome</dd>
        <dt class="col-sm-4">E-mail</dt>
        <dd class="col-sm-8">@Model.Funcionario.Cidadao.Email</dd>
        <dt class="col-sm-4">Departamento</dt>
        <dd class="col-sm-8">@Model.Funcionario.Departamento.Nome</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Funcionario.Id" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>
