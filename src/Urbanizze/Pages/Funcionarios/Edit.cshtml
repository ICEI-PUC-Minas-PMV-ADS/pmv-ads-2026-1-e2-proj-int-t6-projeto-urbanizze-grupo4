@page "{id:int}"
@model Urbanizze.Pages.Funcionarios.EditModel

@{
    ViewData["Title"] = "Editar Funcionário";
}

<h1 class="fs-4 fw-bold mb-3">Editar Funcionário</h1>

<div class="card border p-4" style="max-width: 600px;">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Funcionario.Id" />
        <input type="hidden" asp-for="Funcionario.CidadaoId" />

        <div class="mb-3">
            <label class="form-label">Cidadão</label>
            <input class="form-control" value="@Model.NomeCidadao" disabled />
        </div>

        <div class="mb-3">
            <label asp-for="Funcionario.DepartamentoId" class="form-label">Departamento</label>
            <select asp-for="Funcionario.DepartamentoId" class="form-select"
                    asp-items="Model.Departamentos">
                <option value="">-- Selecione o departamento --</option>
            </select>
            <span asp-validation-for="Funcionario.DepartamentoId" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-dark">Salvar</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
