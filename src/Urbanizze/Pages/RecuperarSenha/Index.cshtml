@page
@model Urbanizze.Pages.RecuperarSenha.IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Recuperar Senha - Urbanizze</title>

    <link rel="stylesheet" href="/css/login/style.css">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body>

    <header class="top-bar">

        <div class="top-logo">
            URBANIZZE
        </div>

        <a href="/Login" class="top-button">
            <i class="fa-solid fa-right-to-bracket"></i>
            Entrar
        </a>

    </header>

    <div class="top-line"></div>

    <div class="container">

        <div class="left-panel">

            <h1>URBANIZZE</h1>

            <div class="line"></div>

            <h2>
                Recuperação de senha
            </h2>

            <p>
                Informe seu e-mail e defina uma nova senha para acessar o sistema novamente.
            </p>

            <div class="features">

                <div class="feature">
                    <i class="fa-solid fa-lock"></i>
                    <span>Segurança</span>
                </div>

                <div class="feature">
                    <i class="fa-solid fa-key"></i>
                    <span>Reset</span>
                </div>

                <div class="feature">
                    <i class="fa-solid fa-user"></i>
                    <span>Acesso</span>
                </div>

            </div>

        </div>

        <div class="right-panel">

            <h2>Recuperar senha</h2>

            <p class="subtitle">
                Use seu e-mail cadastrado.
            </p>

            @if (!string.IsNullOrEmpty(Model.Erro))
            {
                <p style="color:red; margin-bottom:10px;">
                    @Model.Erro
                </p>
            }

            @if (!string.IsNullOrEmpty(Model.Mensagem))
            {
                <p style="color:green; margin-bottom:10px;">
                    @Model.Mensagem
                </p>
            }

            <form method="post">

                <label>E-mail</label>
                <input type="email" asp-for="Email" placeholder="seu@email.com">

                <label>Nova senha</label>
                <input type="password" asp-for="NovaSenha" placeholder="********">

                <label>Confirmar senha</label>
                <input type="password" asp-for="ConfirmarSenha" placeholder="********">

                <button type="submit">
                    Alterar senha
                </button>

            </form>

        </div>

    </div>

</body>
</html>