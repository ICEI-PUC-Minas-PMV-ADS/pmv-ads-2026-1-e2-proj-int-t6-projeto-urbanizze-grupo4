<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Urbanizze</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Urbanizze.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/wwwroot/css/cidadaos.css" asp-append-version="true" />
</head>
<body class="d-flex" style="min-height: 100vh;">

    @* ALINHAR COM O TIME, ANTES DE ATIVAR
    <aside class="d-flex flex-column bg-white border-end" style="width: 200px; min-width: 200px;">
        <div class="px-3 py-3 fw-bold border-bottom">URBANIZZE</div>
        <nav class="flex-grow-1 p-2 d-flex flex-column gap-1">
            <a asp-page="/Usuarios/Index" class="nav-link text-secondary px-3 py-2 rounded">Usuários</a>
            <a asp-page="/Cidadaos/Index" class="nav-link text-secondary px-3 py-2 rounded">Cidadãos</a>
            <a asp-page="/Denuncias/Index" class="nav-link text-secondary px-3 py-2 rounded">Denúncias</a>
        </nav>
        <div class="border-top px-3 py-2 text-muted small">
            Admin User · Administrador
        </div>
    </aside> *@
    
    <div class="d-flex flex-column flex-grow-1">
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container">
                    <a class="navbar-brand" asp-area="" asp-page="/Index">Urbanizze</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
        <div class="container-fluid px-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Urbanizze - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
